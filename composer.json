{
    "name": "porra/porra-mundial-2026",
    "description": "Reusable PHP web application: World Cup pool. Browser installer, MFA, designed for shared hosting (Namecheap / cPanel + FTP).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-curl": "*",
        "ext-sodium": "*",
        "phpmailer/phpmailer": "^6.9",
        "web-auth/webauthn-lib": "^4.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.62"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
